<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Job Monitor Report</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
        "Helvetica Neue", Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
      margin: 0;
      padding: 24px;
      background: #f4f5f7;
      color: #1a1a1a;
      line-height: 1.45;
    }
    .wrap { max-width: 880px; margin: 0 auto; }
    header.summary {
      background: #fff;
      border-radius: 10px;
      padding: 20px 24px;
      margin-bottom: 20px;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
    }
    header.summary h1 { margin: 0 0 4px; font-size: 20px; }
    header.summary .subtitle { color: #555; font-size: 14px; margin: 0 0 12px; }
    header.summary .meta { color: #777; font-size: 13px; }
    .tier-counts { margin: 10px 0 0; padding: 0; list-style: none;
      display: flex; flex-wrap: wrap; gap: 8px; }
    .tier-counts li {
      font-size: 13px; padding: 3px 10px; border-radius: 999px;
      background: #eef0f3; color: #333;
    }
    .card {
      background: #fff;
      border-radius: 10px;
      padding: 18px 22px;
      margin-bottom: 16px;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
      border-left: 5px solid #c7ccd4;
    }
    .card--alert {
      border-left-color: #d92d20;
      background: #fff7f6;
    }
    .card h2 { margin: 0 0 4px; font-size: 17px; }
    .card .company-line { color: #444; font-size: 14px; margin: 0 0 12px; }
    .badge {
      display: inline-block; font-size: 12px; font-weight: 600;
      padding: 2px 9px; border-radius: 6px; margin-left: 8px;
      vertical-align: middle; background: #e7eefc; color: #1747b8;
    }
    .badge--alert { background: #fde7e5; color: #b42318; }
    dl.fields { margin: 0; display: grid; grid-template-columns: 180px 1fr;
      gap: 4px 12px; font-size: 14px; }
    dl.fields dt { color: #666; font-weight: 600; }
    dl.fields dd { margin: 0; }
    ul.reasons, ul.tips { margin: 4px 0 0; padding-left: 20px; }
    ul.reasons li, ul.tips li { font-size: 14px; }
    a { color: #1747b8; word-break: break-all; }
    .empty { background: #fff; border-radius: 10px; padding: 24px;
      text-align: center; color: #777; }
    h2.section { margin: 26px 0 12px; font-size: 16px; color: #1a1a1a;
      border-bottom: 2px solid #d6dae1; padding-bottom: 6px; }
    .section-empty { font-size: 13px; color: #999; margin: 0 0 16px; }
    .tabs {
      display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 16px;
      border-bottom: 2px solid #d6dae1;
    }
    .tab-btn {
      appearance: none; border: 1px solid #d6dae1; border-bottom: none;
      background: #eef0f3; color: #444; font: inherit; font-size: 14px;
      font-weight: 600; cursor: pointer; padding: 9px 16px;
      border-radius: 8px 8px 0 0; margin-bottom: -2px;
    }
    .tab-btn:hover { background: #e3e6ea; }
    .tab-btn.is-active {
      background: #fff; color: #1747b8; border-color: #d6dae1;
      border-bottom: 2px solid #fff;
    }
    .tab-panel { display: none; }
    .tab-panel.is-active { display: block; }
    .stars { color: #e6a700; letter-spacing: 1px; }
    .recruiter {
      display: inline-block; font-size: 12px; font-weight: 600;
      padding: 2px 9px; border-radius: 6px; margin-left: 8px;
      vertical-align: middle; background: #fff3e0; color: #9a5b00;
    }
    footer { color: #999; font-size: 12px; text-align: center; margin-top: 24px; }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="summary">
      <h1>职位监控报告 / Job Monitor Report</h1>
      {% if subtitle %}<p class="subtitle">{{ subtitle }}</p>{% endif %}
      <p class="meta">生成时间 / Generated: {{ generated_at.strftime("%Y-%m-%d %H:%M") }}
        · 共 / Total: {{ total }}</p>
      <ul class="tier-counts">
        {% for tier, count in counts.items() %}
          <li>{{ tier }}: {{ count }}</li>
        {% endfor %}
      </ul>
    </header>

    {% if not sections %}
      <div class="empty">无匹配职位 / No matches</div>
    {% endif %}

    {% if sections %}
    <div class="tabs" role="tablist">
      {% for section in sections %}
        <button type="button" class="tab-btn{% if loop.first %} is-active{% endif %}"
          role="tab" aria-controls="tab-panel-{{ loop.index }}"
          aria-selected="{{ 'true' if loop.first else 'false' }}"
          data-tab-target="tab-panel-{{ loop.index }}">
          {{ section.heading }} ({{ section.items | length }})
        </button>
      {% endfor %}
    </div>
    {% endif %}

    {% for section in sections %}
      <section class="tab-panel{% if loop.first %} is-active{% endif %}"
        id="tab-panel-{{ loop.index }}" role="tabpanel">
      <h2 class="section">{{ section.heading }} ({{ section.items | length }})</h2>
      {% for item in section.items %}
        {% set job = item.job %}
        {% set is_alert = job.strong_alert or (job.priority_tier and job.priority_tier.value == "A+") %}
        <article class="card{% if is_alert %} card--alert{% endif %}">
          <h2>
            {{ job.title }}
            {% if job.priority_tier %}
              <span class="badge{% if is_alert %} badge--alert{% endif %}">{{ job.priority_tier.value }}</span>
            {% endif %}
            {% if job.strong_alert %}<span class="badge badge--alert">强烈推荐 / Strong</span>{% endif %}
          </h2>
          <p class="company-line">{{ job.company_name }}{% if job.location %} · {{ job.location }}{% endif %}{% if item.recruiter %}<span class="recruiter">{{ item.recruiter }}</span>{% endif %}</p>
          <dl class="fields">
            <dt>职位 / Title</dt><dd>{{ job.title }}</dd>
            <dt>公司 / Company</dt><dd>{{ job.company_name }}</dd>
            <dt>评分 / Rating</dt><dd>{% if item.stars %}<span class="stars">{{ item.stars }}</span>{% elif item.recruiter %}{{ item.recruiter }}{% else %}—{% endif %}</dd>
            <dt>地点 / Location</dt><dd>{{ job.location or "—" }}</dd>
            <dt>薪资 / Salary</dt><dd>{{ salary_of(job) }}</dd>
            <dt>来源 / Source</dt><dd>{{ job.source.value }}</dd>
            <dt>发布日期 / Posted</dt><dd>{{ job.posted_date.isoformat() if job.posted_date else "—" }}</dd>
            <dt>申请链接 / Apply</dt><dd><a href="{{ job.apply_url }}">{{ job.apply_url }}</a></dd>
            <dt>Final score</dt><dd>{{ "%.1f"|format(job.final_score) if job.final_score is not none else "—" }}</dd>
            <dt>优先级 / Priority</dt><dd>{{ job.priority_tier.value if job.priority_tier else "—" }}</dd>
            <dt>匹配原因 / Match reasons</dt>
            <dd>
              {% if job.match_reasons %}
                <ul class="reasons">{% for r in job.match_reasons %}<li>{{ r }}</li>{% endfor %}</ul>
              {% else %}—{% endif %}
            </dd>
            <dt>简历建议 / Resume tips</dt>
            <dd>
              {% if job.resume_tips %}
                <ul class="tips">{% for t in job.resume_tips %}<li>{{ t }}</li>{% endfor %}</ul>
              {% else %}—{% endif %}
            </dd>
          </dl>
        </article>
      {% endfor %}
      </section>
    {% endfor %}

    <footer>Job Monitor · {{ generated_at.strftime("%Y-%m-%d %H:%M") }}</footer>
  </div>
  <script>
    (function () {
      var buttons = document.querySelectorAll(".tab-btn");
      function activate(targetId) {
        var i;
        for (i = 0; i < buttons.length; i++) {
          var btn = buttons[i];
          var isTarget = btn.getAttribute("data-tab-target") === targetId;
          btn.classList.toggle("is-active", isTarget);
          btn.setAttribute("aria-selected", isTarget ? "true" : "false");
        }
        var panels = document.querySelectorAll(".tab-panel");
        for (i = 0; i < panels.length; i++) {
          panels[i].classList.toggle("is-active", panels[i].id === targetId);
        }
      }
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].addEventListener("click", function () {
          activate(this.getAttribute("data-tab-target"));
        });
      }
    })();
  </script>
</body>
</html>
